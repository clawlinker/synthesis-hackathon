{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "defaultWallet": {
      "type": "string",
      "description": "Default wallet address to show receipts for",
      "default": "0x5793BFc1331538C5A8028e71Cc22B43750163af8"
    },
    "showInferenceReceipts": {
      "type": "boolean",
      "description": "Whether to show Bankr LLM inference receipts",
      "default": true
    },
    "apiEndpoint": {
      "type": "string",
      "description": "Custom API endpoint override",
      "pattern": "^https://",
      "default": "https://pawr.link/api"
    },
    "autoRefresh": {
      "type": "boolean",
      "description": "Automatically refresh receipts on tab activation",
      "default": true
    },
    "refreshInterval": {
      "type": "number",
      "description": "Refresh interval in seconds (minimum 60)",
      "minimum": 60,
      "default": 300
    }
  },
  "additionalProperties": false
}
